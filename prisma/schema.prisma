generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  UNDERWRITER
  FINANCE
  AGENT
  BANK
  VIEWER
}

enum Gender {
  MALE
  FEMALE
}

enum CountryCategory {
  ALLOWED
  RESTRICTED
  HIGH_RISK
}

enum CountryStatus {
  ACTIVE
  INACTIVE
}

enum PolicyType {
  INDIVIDUAL
  FAMILY
  STUDENT
  BUSINESS
  MULTI_TRIP
}

enum PolicyStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TravelPurpose {
  TOURISM
  BUSINESS
  STUDY
  MEDICAL
  OTHER
}

enum ClaimType {
  MEDICAL
  BAGGAGE
  TRIP_DELAY
  CANCELLATION
  OTHER
}

enum ClaimStatus {
  OPEN
  UNDER_REVIEW
  APPROVED
  REJECTED
  CLOSED
}

enum NotificationType {
  SYSTEM
  EXPIRY
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum EndorsementType {
  EXTEND_TRAVEL_PERIOD
  CHANGE_DESTINATION
  UPDATE_CUSTOMER_INFORMATION
  INCREASE_COVERAGE_AMOUNT
}

enum EndorsementStatus {
  OPEN
  UNDER_REVIEW
  APPROVED
  REJECTED
  CLOSED
}

enum CancellationReason {
  VISA_REJECTION
  TRIP_CANCELLATION
  CUSTOMER_REQUEST
  ISSUANCE_ERROR
}

enum LookupCategory {
  CLAIM_TYPE
  DESTINATION
  TRAVEL_PLAN
  POLICY_TYPE
  COVERAGE_TYPE
  ENDORSEMENT_TYPE
  CANCELLATION_REASON
}

enum MotorRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_INFO
  APPROVED
  REJECTED
}

enum PortalRequestType {
  MOTOR
  CIVIL_LIABILITY
  TRAVEL
  BUILDING_GLASS
  FIDELITY_GUARANTEE
  CASH_IN_SAFE
  CONTRACTORS_ALL_RISKS
  PERSONAL_ACCIDENT
  WORKERS_COMPENSATION
}

enum ReferralType {
  MARINE
  ENGINEERING
  HEALTH
  OTHER
}

enum ReferralStatus {
  RECEIVED
  UNDER_REVIEW
  CONTACTING
  ISSUED
}

enum TransportMode {
  SEA
  LAND
  AIR
}

enum ReportRequestStatus {
  PENDING
  IN_REVIEW
  COMPLETED
  REJECTED
}

model Agency {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  active    Boolean  @default(true)
  users     User[]
  policies  Policy[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role       @default(VIEWER)
  active        Boolean    @default(true)
  localePreference String  @default("ar")
  themePreference  String  @default("system")
  agencyId      String?
  agency        Agency?    @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  accounts      Account[]
  sessions      Session[]
  activities    Activity[]
  customers     Customer[]  @relation("CustomerCreator")
  policies      Policy[]   @relation("PolicyIssuer")
  ownedPolicies Policy[]   @relation("PolicyOwner")
  motorRequests MotorInsuranceRequest[] @relation("MotorRequestAgent")
  motorCommissions MotorCommission[] @relation("MotorCommissionPayer")
  referrals Referral[] @relation("ReferralCreator")
  referralCommissions ReferralCommission[] @relation("ReferralCommissionPayer")
  reportRequests ReportRequest[] @relation("ReportRequestRequester")
  reviewedReportRequests ReportRequest[] @relation("ReportRequestReviewer")
  claims        Claim[]     @relation("ClaimCreator")
  notifications Notification[]
  auditLogs     AuditLog[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([agencyId])
}

model MotorInsuranceRequest {
  id                    String             @id @default(cuid())
  requestNumber         String             @unique
  submissionToken       String             @unique
  requestType           PortalRequestType  @default(MOTOR)
  portalPayload         Json               @default("{}")
  portalAttachments     Json               @default("[]")
  status                MotorRequestStatus @default(SUBMITTED)
  customerFullName      String
  customerMobile        String
  customerEmail         String?
  customerNationalId    String?
  customerAddress       String?
  customerCity          String?
  vehicleType           String?
  manufacturer          String?
  model                 String?
  manufacturingYear     Int?
  color                 String?
  plateNumber           String?
  chassisNumber         String?
  engineNumber          String?
  estimatedVehicleValue Decimal?           @db.Decimal(12, 2)
  vehicleImages         Json
  customerDocuments     Json
  uploadFailures        Json               @default("[]")
  notes                 String?            @db.Text
  agentId               String?
  agent                 User?              @relation("MotorRequestAgent", fields: [agentId], references: [id], onDelete: SetNull)
  source                String             @default("Internal")
  agentName             String
  agentEmail            String?
  agentRole             Role?
  agentAgency           String?
  userId                String?
  createdDate           DateTime           @default(now())
  createdTime           String
  reviewedById          String?
  reviewedByName        String?
  reviewedAt            DateTime?
  managerNotes          String?            @db.Text
  coverageType          String?
  coverageNotes         String?            @db.Text
  insurancePremium      Decimal            @default(0) @db.Decimal(12, 2)
  discount              Decimal            @default(0) @db.Decimal(12, 2)
  additionalFees        Decimal            @default(0) @db.Decimal(12, 2)
  taxes                 Decimal            @default(0) @db.Decimal(12, 2)
  netPremium            Decimal            @default(0) @db.Decimal(12, 2)
  pricingCurrency       String             @default("IQD")
  pricingNotes          String?            @db.Text
  policyTermsHtml       String?            @db.Text
  termsApprovedById     String?
  termsApprovedByName   String?
  termsApprovedAt       DateTime?
  underwriterSignature  Json?
  managerSignature      Json?
  companyStamp          Json?
  approvedById          String?
  approvedByName        String?
  approvedAt            DateTime?
  issuedPolicyNumber    String?
  policyIssuedAt        DateTime?
  editHistory           Json               @default("[]")
  commission            MotorCommission?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([status])
  @@index([requestType])
  @@index([agentId])
  @@index([createdAt])
  @@index([customerNationalId])
  @@index([plateNumber])
  @@index([policyIssuedAt])
}

model Referral {
  id                    String           @id @default(cuid())
  referralNumber        String           @unique
  type                  ReferralType     @default(MARINE)
  status                ReferralStatus   @default(RECEIVED)
  applicantName         String?
  beneficiaryName       String?
  insuredAmount         Decimal?         @db.Decimal(12, 2)
  insuranceFrom         DateTime?
  insuranceTo           DateTime?
  totalInsuredAfterIncrease Decimal?     @db.Decimal(12, 2)
  increaseRate          Decimal?         @db.Decimal(5, 2)
  coverType             String?
  cargoDescription      String?          @db.Text
  routeFrom             String?
  routeTo               String?
  transportMode         TransportMode?
  packagingType         String?
  lcNumber              String?
  carrierName           String?
  invoiceNumber         String?
  currency              String           @default("IQD")
  extraRisks            String[]         @default([])
  hasPreviousCompensation Boolean        @default(false)
  totalPremium          Decimal          @default(0) @db.Decimal(12, 2)
  notes                 String?          @db.Text
  takafulAttachments    Json             @default("[]")
  createdById           String?
  createdBy             User?            @relation("ReferralCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdByName         String?
  createdByEmail        String?
  createdByRole         Role?
  createdByBank         String?
  issuedAt              DateTime?
  installments          ReferralInstallment[]
  commission            ReferralCommission?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdById])
  @@index([createdAt])
  @@index([issuedAt])
}

model ReferralInstallment {
  id          String    @id @default(cuid())
  referralId  String
  referral    Referral  @relation(fields: [referralId], references: [id], onDelete: Cascade)
  label       String?
  amount      Decimal?  @db.Decimal(12, 2)
  dueDate     DateTime?
  paid        Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([referralId])
}

model ReferralCommission {
  id               String    @id @default(cuid())
  referralId       String    @unique
  referral         Referral  @relation(fields: [referralId], references: [id], onDelete: Cascade)
  premiumAmount    Decimal   @db.Decimal(12, 2)
  commissionRate   Decimal   @db.Decimal(5, 2)
  commissionAmount Decimal   @db.Decimal(12, 2)
  currency         String    @default("IQD")
  paid             Boolean   @default(true)
  paidAt           DateTime  @default(now())
  paidById         String?
  paidBy           User?     @relation("ReferralCommissionPayer", fields: [paidById], references: [id], onDelete: SetNull)
  paidByName       String?
  paidToName       String?
  paidToBank       String?
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([paidAt])
  @@index([paidById])
}

model ReportRequest {
  id             String              @id @default(cuid())
  requestNumber  String              @unique
  title          String
  details        String              @db.Text
  status         ReportRequestStatus @default(PENDING)
  requesterId    String?
  requester      User?               @relation("ReportRequestRequester", fields: [requesterId], references: [id], onDelete: SetNull)
  requesterName  String?
  requesterEmail String?
  requesterRole  Role?
  requesterBank  String?
  managerNotes   String?             @db.Text
  reportFileUrl  String?
  reportFileName String?
  reportFileType String?
  reportFileSize Int?
  reportFileUploadedAt DateTime?
  isLocked       Boolean             @default(false)
  lockedAt       DateTime?
  lockedById     String?
  lockedByName   String?
  reviewedById   String?
  reviewedBy     User?               @relation("ReportRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedByName String?
  reviewedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([status])
  @@index([requesterId])
  @@index([createdAt])
  @@index([reviewedById])
}

model MotorCommission {
  id              String                @id @default(cuid())
  motorRequestId  String                @unique
  motorRequest    MotorInsuranceRequest @relation(fields: [motorRequestId], references: [id], onDelete: Cascade)
  premiumAmount   Decimal               @db.Decimal(12, 2)
  commissionRate  Decimal               @db.Decimal(5, 2)
  commissionAmount Decimal              @db.Decimal(12, 2)
  currency        String                @default("IQD")
  paid            Boolean               @default(true)
  paidAt          DateTime              @default(now())
  paidById        String?
  paidBy          User?                 @relation("MotorCommissionPayer", fields: [paidById], references: [id], onDelete: SetNull)
  paidByName      String?
  notes           String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([paid])
  @@index([paidAt])
  @@index([paidById])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Customer {
  id              String    @id @default(cuid())
  arabicName      String
  englishName     String
  passportNumber  String    @unique
  nationality     String
  dateOfBirth     DateTime
  gender          Gender
  mobile          String
  email           String?
  address         String?
  passportImage   String?
  createdByUserId String?
  createdBy        User?     @relation("CustomerCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdByName    String?
  createdByEmail   String?
  createdByRole    Role?
  createdByAgency  String?
  policies        Policy[]
  claims          Claim[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([arabicName])
  @@index([englishName])
  @@index([passportNumber])
  @@index([createdByUserId])
}

model TravelPlan {
  id                 String    @id @default(cuid())
  name               String    @unique
  price              Decimal   @db.Decimal(10, 2)
  medicalCoverage    Decimal   @db.Decimal(12, 2)
  baggageCoverage    Decimal   @db.Decimal(12, 2)
  tripDelayCoverage  Decimal   @db.Decimal(12, 2)
  medicalEvacuation  Decimal   @db.Decimal(12, 2)
  repatriation       Decimal   @db.Decimal(12, 2)
  personalLiability  Decimal   @db.Decimal(12, 2)
  active             Boolean   @default(true)
  policies           Policy[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Country {
  id                String          @id @default(cuid())
  nameAr            String
  nameEn            String          @unique
  isoCode           String          @unique
  category          CountryCategory @default(ALLOWED)
  additionalRiskFee Decimal         @default(0) @db.Decimal(10, 2)
  status            CountryStatus   @default(ACTIVE)
  policies          Policy[]
  endorsements      Endorsement[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model Policy {
  id                 String         @id @default(cuid())
  policyNumber       String         @unique
  customerId         String
  customer           Customer       @relation(fields: [customerId], references: [id])
  destinationCountryId String
  destinationCountry Country        @relation(fields: [destinationCountryId], references: [id])
  destinations       String[]
  travelPurpose      TravelPurpose
  departureDate      DateTime
  returnDate         DateTime
  numberOfDays       Int
  coverageAmount     Decimal        @db.Decimal(12, 2)
  policyType         String
  coverageType       String         @default("STANDARD")
  travelPlanId       String
  travelPlan         TravelPlan     @relation(fields: [travelPlanId], references: [id])
  premium            Decimal        @db.Decimal(10, 2)
  status             PolicyStatus   @default(DRAFT)
  qrCodeData         String?        @db.Text
  issuedById         String?
  issuedBy           User?          @relation("PolicyIssuer", fields: [issuedById], references: [id])
  issuedByUserId     String?
  owner              User?          @relation("PolicyOwner", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  issuedByName       String?
  issuedByEmail      String?
  issuedByRole       Role?
  issuedByAgency     String?
  agencyId           String?
  agency             Agency?        @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  deletedAt          DateTime?
  deletedBy          String?
  claims             Claim[]
  endorsements       Endorsement[]
  cancellation       Cancellation?
  issuedAt           DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([policyNumber])
  @@index([status])
  @@index([departureDate, returnDate])
  @@index([issuedByUserId])
  @@index([agencyId])
  @@index([deletedAt])
}

model Activity {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Claim {
  id           String      @id @default(cuid())
  claimNumber  String      @unique
  policyId     String
  policy       Policy      @relation(fields: [policyId], references: [id])
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  claimType    String
  description  String      @db.Text
  attachments  String[]
  status       ClaimStatus @default(OPEN)
  createdById  String?
  createdBy    User?       @relation("ClaimCreator", fields: [createdById], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([claimNumber])
  @@index([status])
}

model Endorsement {
  id                 String            @id @default(cuid())
  endorsementNumber  String            @unique
  policyId           String
  policy             Policy            @relation(fields: [policyId], references: [id])
  endorsementType    String
  previousValue      Json?
  newValue           Json
  destinationCountryId String?
  destinationCountry Country?          @relation(fields: [destinationCountryId], references: [id])
  additionalPremium  Decimal           @default(0) @db.Decimal(10, 2)
  status             EndorsementStatus @default(OPEN)
  createdById        String?
  createdByName      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([createdById])
}

model Cancellation {
  id                 String             @id @default(cuid())
  cancellationNumber String             @unique
  policyId           String             @unique
  policy             Policy             @relation(fields: [policyId], references: [id])
  reason             String
  notes              String?            @db.Text
  refundAmount       Decimal            @db.Decimal(10, 2)
  administrativeFees Decimal            @db.Decimal(10, 2)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role      Role?
  agency    String?
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String?
  user      User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String             @db.Text
  entity    String?
  entityId  String?
  status    NotificationStatus @default(PENDING)
  dueAt     DateTime?
  sentAt    DateTime?
  createdAt DateTime           @default(now())

  @@index([status])
  @@index([dueAt])
}

model LookupValue {
  id        String         @id @default(cuid())
  category  LookupCategory
  value     String
  labelAr   String
  labelEn   String?
  active    Boolean        @default(true)
  system    Boolean        @default(false)
  sortOrder Int            @default(0)
  createdBy String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([category, value])
  @@index([category, active, sortOrder])
}
